# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=TAXUP
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# ── Database ───────────────────────────────────────────────────────────────────
# Used by docker-compose to build the connection string
DB_PASSWORD=3db806ec1b2850118903c9f858037887d9b331ab9392bd21
DATABASE_URL=postgresql://taxup_user:3db806ec1b2850118903c9f858037887d9b331ab9392bd21@postgres:5432/taxup

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
SECRET_KEY=j40ULzPLS11afbLwZ1JcUYvimeGsv7tT3glCxAB8ollf03F4QJErSa0ZGoMWO62v
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Signing Keys (Docker Secrets paths) ───────────────────────────────────────
PRIVATE_KEY_PATH=/run/secrets/private_key
PUBLIC_KEY_PATH=/run/secrets/public_key

# ── Tax Configuration ─────────────────────────────────────────────────────────
DEFAULT_TAX_RATE=0.18
FRAUD_RISK_THRESHOLD=0.75

# ── CORS ──────────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=http://localhost:3000,https://taxup.gov

